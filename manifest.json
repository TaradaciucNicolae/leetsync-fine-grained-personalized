{
  "manifest_version": 2,
  "name": "LeetSync Fine-Grained - Personalized",
  "description": "Privacy-first Firefox extension for syncing accepted LeetCode solutions to one GitHub repository with a Fine-Grained PAT.",
  "version": "0.1.0",
  "author": "Derived from LeetHub by Qasim Wani; independently modified",
  "browser_specific_settings": {
    "gecko": {
      "id": "leetsync-fine-grained-personalized@taradaciucnicolae",
      "strict_min_version": "109.0"
    }
  },
  "browser_action": {
    "default_icon": "assets/thumbnail.png",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/thumbnail.png",
    "48": "assets/thumbnail.png",
    "128": "assets/thumbnail.png"
  },
  "background": {
    "scripts": ["scripts/background.js"],
    "persistent": false
  },
  "permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "scripts/leetcode.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "scripts/leetcode-page-bridge.js"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'"
}
