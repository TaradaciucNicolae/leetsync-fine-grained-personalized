{
  "manifest_version": 2,
  "name": "LeetSync Fine-Grained - Personalized",
  "description": "Firefox extension for syncing accepted LeetCode solutions to one configured GitHub repository with a Fine-Grained PAT.",
  "version": "0.1.0",
  "author": "Derived from LeetHub by Qasim Wani; independently modified",
  "browser_specific_settings": {
    "gecko": {
      "id": "leetsync-fine-grained-personalized@taradaciucnicolae",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "browsingActivity",
          "websiteContent"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "browser_action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "scripts": ["scripts/background.js"],
    "persistent": false
  },
  "permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "scripts/leetcode.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "scripts/leetcode-page-bridge.js"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'"
}
